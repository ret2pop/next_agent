{
  "type": "function",
  "function": {
    "name": "list_directory",
    "description": "List all files (including hidden) in a directory using `ls -a`",
    "parameters": {
      "type": "object",
      "properties": {
        "path": {
          "description": "The directory path to list",
          "type": "string"
        }
      },
      "required": [
        "path"
      ]
    }
  },
  "bash_template": "ls -a {{{path}}}"
}